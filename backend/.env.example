# Database
DATABASE_URL=postgresql://user:password@localhost:5432/bumiagent

# OpenRouter (LLM gateway)
OPENROUTER_API_KEY=sk-or-v1-xxx

# Wallet encryption (64 hex chars = 32 bytes)
ENCRYPTION_MASTER_KEY=

# Treasury wallet for subscription payments
TREASURY_ADDRESS=0x...

# Redis (optional — rate limiting disabled without it)
REDIS_URL=redis://localhost:6379

# Server
PORT=3001
NODE_ENV=development
